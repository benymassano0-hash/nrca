POSTGRES_USER=rcna
POSTGRES_PASSWORD=trocar-esta-password
POSTGRES_DB=rcna

JWT_SECRET=trocar-esta-chave-super-segura

# URL pública permitida a chamar o backend (separar múltiplas por vírgula)
FRONTEND_ORIGINS=https://seu-dominio.com

# URL da API usada no build do frontend
REACT_APP_API_URL=https://api.seu-dominio.com/api

# Ative apenas se o seu PostgreSQL exigir SSL
DB_SSL=false